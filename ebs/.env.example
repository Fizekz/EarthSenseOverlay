# Websocket URL for the robot's Unified Bridge (reachable over the robot's
# own wifi network — this machine is wired to ethernet and also joins that
# wifi). PLACEHOLDER: the Unified Bridge itself is being built separately;
# see app/bridge_client.py for what's stubbed and why.
BRIDGE_WS_URL=ws://192.168.4.1:8765/ws
BRIDGE_RECONNECT_DELAY_S=3.0
BRIDGE_COMMAND_TIMEOUT_S=5.0

# Twitch Extension secret (base64, from the dev console) — verifies the JWT
# the extension sends on every request.
TWITCH_EXTENSION_SECRET=

# Origins allowed to call this service from a browser. "*" for local dev only.
CORS_ALLOW_ORIGINS=*

# Skips JWT verification when true (dev/local preview only).
EBS_DEV_MODE=false

# Busy-lock / cooldown knobs (see app/dispatcher.py)
ROUTE_LOCK_SECONDS=120
USER_COOLDOWN_SECONDS=60
