# tsp-core-service REST base URL (see documentation.txt)
TSP_BASE_URL=http://localhost:8080
TSP_TIMEOUT_S=5.0

# Twitch Extension secret (base64), from the Twitch developer console.
# Used to verify the JWT the extension frontend sends on every request.
TWITCH_EXTENSION_SECRET=

# Shared secret between this service and EarthSenseBot. Generate any long
# random string and put the same value in both .env files.
EBS_BOT_SHARED_SECRET=

# Comma-separated list of origins allowed to call this service from a
# browser (your extension's frontend origin). "*" is fine for local dev only.
CORS_ALLOW_ORIGINS=*

# When true, skips real JWT verification and treats every extension request
# as an authorized local viewer. Only for local preview (mirrors the
# overlay's own "Local preview" fallback) — never enable this in production.
EBS_DEV_MODE=false

# Physical-safety knobs (see app/dispatcher.py)
ROUTE_LOCK_SECONDS=120
USER_COOLDOWN_SECONDS=60
