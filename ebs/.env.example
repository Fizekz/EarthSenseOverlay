# Websocket URL for the robot (reachable over the robot's own wifi network —
# this machine is wired to ethernet and also joins that wifi). TEMPORARY
# DIRECT-TO-CONTROLLER MODE: pointed straight at the TSP controller's
# terra_controller socket, bypassing the broken unified_bridge (see
# app/bridge_client.py). Goes back to ws://<bridge-host>:9100 once that's fixed.
BRIDGE_WS_URL=ws://192.168.1.135:9000/terra_controller
BRIDGE_RECONNECT_DELAY_S=3.0
BRIDGE_COMMAND_TIMEOUT_S=5.0
BRIDGE_STATUS_POLL_INTERVAL_S=1.5

# Twitch Extension secret (base64, from the dev console) — verifies the JWT
# the extension sends on every request.
TWITCH_EXTENSION_SECRET=

# Origins allowed to call this service from a browser. "*" for local dev only.
CORS_ALLOW_ORIGINS=*

# Skips JWT verification when true (dev/local preview only).
EBS_DEV_MODE=false

# Busy-lock / cooldown knobs (see app/dispatcher.py). TEMPORARY: 2s defaults
# match the forward/backward drive-pulse test in routes_config.py
# (PULSE_DURATION_S=1.5s) — bump back up once routes_config.py goes back to
# longer-running preset routes.
ROUTE_LOCK_SECONDS=2
USER_COOLDOWN_SECONDS=2
